# Copy to .env and fill in your key.
# .env is gitignored. Do not commit real keys.

# All model calls (VaxBot panel + paraphrase generator + judge) route through
# OpenRouter using its OpenAI-compatible API. One key, all providers.
# Get at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional fallbacks if you want to bypass OpenRouter for a specific provider:
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
